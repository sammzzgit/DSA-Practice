class Solution {
    public int subarraySum(int[] nums, int k) {
        int count = 0, prefixSum = 0;
    Map<Integer, Integer> freq = new HashMap<>();
    freq.put(0, 1);

    for (int num : nums) {
        prefixSum += num;
        count += freq.getOrDefault(prefixSum - k, 0);
        freq.put(prefixSum, freq.getOrDefault(prefixSum, 0) + 1);
    }
    return count;
    }
}
